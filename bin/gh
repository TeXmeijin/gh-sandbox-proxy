#!/usr/bin/env python3
"""
Token-hiding GitHub CLI wrapper.

Place this command before the real `gh` in PATH. It obtains a GitHub App User
Access Token via ghtkn for each `gh` invocation, injects the token only into the
real `gh` child process, and blocks token-printing commands on the wrapper
interface.
"""

from __future__ import annotations

import os
import shlex
import subprocess
import sys
from pathlib import Path


APP = "gh-sandbox-proxy"
DEFAULT_REAL_GH_BIN = "/opt/homebrew/bin/gh"
DEFAULT_GHTKN_BIN = "/opt/homebrew/bin/ghtkn"


def eprint(message: str = "") -> None:
    print(message, file=sys.stderr)


def executable(path: str) -> bool:
    return Path(path).is_file() and os.access(path, os.X_OK)


def real_gh_bin() -> str:
    gh = os.environ.get("GH_SANDBOX_REAL_GH") or DEFAULT_REAL_GH_BIN
    if executable(gh):
        return gh
    raise SystemExit(f"{APP}: real gh not found or not executable: {gh}")


def ghtkn_bin() -> str:
    ghtkn = os.environ.get("GH_SANDBOX_GHTKN_BIN") or DEFAULT_GHTKN_BIN
    if executable(ghtkn):
        return ghtkn
    raise SystemExit(f"{APP}: ghtkn not found or not executable: {ghtkn}")


def ghtkn_app_name() -> str:
    app_name = os.environ.get("GHTKN_APP_NAME", "").strip()
    if app_name:
        return app_name
    raise SystemExit(
        f"{APP}: GHTKN_APP_NAME is required.\n"
        f"{APP}: set it per project, for example with direnv or shell startup:\n"
        f"{APP}:   export GHTKN_APP_NAME=owner/app-name"
    )


def pattern_matches(args: list[str], pattern: list[str]) -> bool:
    return len(args) >= len(pattern) and args[: len(pattern)] == pattern


def is_blocked(args: list[str]) -> bool:
    blocked = [
        ["auth", "token"],
        ["auth", "status", "--show-token"],
    ]
    return any(pattern_matches(args, pattern) for pattern in blocked)


def is_api_write(args: list[str]) -> tuple[bool, str]:
    if not args or args[0] != "api":
        return False, ""

    read_methods = {"GET", "HEAD", "OPTIONS"}
    is_graphql = len(args) >= 2 and args[1] == "graphql"
    field_flags = {"-F", "-f", "--field", "--raw-field"}

    i = 1
    while i < len(args):
        arg = args[i]
        if arg in {"-X", "--method"} and i + 1 < len(args):
            method = args[i + 1].upper()
            if method not in read_methods:
                return True, f"non-GET method: {method}"
            i += 2
            continue
        if arg.startswith("--method="):
            method = arg.split("=", 1)[1].upper()
            if method not in read_methods:
                return True, f"non-GET method: {method}"
        if arg == "--input" or arg.startswith("--input="):
            return True, "--input implies request body"
        if arg in field_flags:
            if is_graphql:
                if i + 1 < len(args):
                    value = args[i + 1].lower().lstrip()
                    if value.startswith("query=") and "mutation" in value:
                        return True, "GraphQL mutation detected"
                i += 2
                continue
            return True, f"field flag implies request body: {arg}"
        if any(arg.startswith(f"{flag}=") for flag in field_flags):
            if is_graphql:
                value = arg.split("=", 1)[1].lower().lstrip()
                if value.startswith("query=") and "mutation" in value:
                    return True, "GraphQL mutation detected"
            else:
                return True, f"field flag implies request body: {arg.split('=', 1)[0]}"
        i += 1

    return False, ""


def ghtkn_token(app_name: str) -> str:
    proc = subprocess.run(
        [ghtkn_bin(), "get", app_name],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=None,
    )
    if proc.returncode != 0:
        raise SystemExit(proc.returncode)

    token = proc.stdout.strip()
    if not token.startswith("ghu_"):
        raise SystemExit(f"{APP}: ghtkn returned an unexpected token prefix")
    return token


def print_help() -> None:
    print(
        """gh-sandbox-proxy

Host-side `gh` wrapper for ghtkn-backed GitHub App User Access Tokens.

Behavior:
  gh <any gh command>        run real gh with a per-command ghtkn token
  gh auth token             blocked on purpose
  gh auth status --show-token
                            blocked on purpose

Required environment:
  GHTKN_APP_NAME=owner/app-name

Optional environment:
  GH_SANDBOX_REAL_GH=/path/to/gh
  GH_SANDBOX_GHTKN_BIN=/path/to/ghtkn
  GH_SANDBOX_ALLOW_WRITE=1  allow write-likely `gh api` calls
"""
    )


def main() -> int:
    args = sys.argv[1:]

    if not args or args in (["--help"], ["help"], ["-h"]):
        print_help()
        return 0

    if is_blocked(args):
        eprint(f"{APP}: blocked: this wrapper never exposes GitHub auth tokens on the host interface.")
        eprint(f"{APP}: command was: gh {' '.join(shlex.quote(arg) for arg in args)}")
        return 2

    if args[0] == "api" and not os.environ.get("GH_SANDBOX_ALLOW_WRITE"):
        is_write, reason = is_api_write(args)
        if is_write:
            eprint(f"{APP}: blocked write-likely `gh api` ({reason}).")
            eprint(f"{APP}: command was: gh {' '.join(shlex.quote(arg) for arg in args)}")
            eprint(f"{APP}: to override for one shell session, run:")
            eprint(f"{APP}:   export GH_SANDBOX_ALLOW_WRITE=1")
            return 2

    token = ghtkn_token(ghtkn_app_name())
    env = os.environ.copy()
    env["GH_TOKEN"] = token
    env["GITHUB_TOKEN"] = token
    proc = subprocess.run([real_gh_bin(), *args], env=env)
    return proc.returncode


if __name__ == "__main__":
    raise SystemExit(main())
